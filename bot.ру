from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import Updater, CommandHandler, CallbackQueryHandler, MessageHandler, Filters, CallbackContext

# === Настройки ===
TOKEN = "8762191293:AAGpFFHJpgIIQAJR6TNBpJNJikdKpwgM4qg"   # твой токен
YOUR_ID = 7822572763                                        # твой Telegram ID
CHANNEL_ID = "@ishutebyazai"                                # канал для публикации одобренных сообщений

# === Хранение сообщений ===
pending_messages = {}  # ID: {"text": текст, "user": ник или "Аноним"}
approved_messages = []  # список одобренных сообщений

# === Команда /start ===
def start(update: Update, context: CallbackContext):
    keyboard = [
        [InlineKeyboardButton("Анонимно", callback_data='anon')],
        [InlineKeyboardButton("Не анонимно", callback_data='nonanon')]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    update.message.reply_text('Выберите режим отправки сообщения:', reply_markup=reply_markup)

# === Обработка кнопок выбора анонимности ===
def button(update: Update, context: CallbackContext):
    query = update.callback_query
    query.answer()
    context.user_data['anon'] = (query.data == 'anon')
    query.edit_message_text(text="Напишите ваше сообщение:")

# === Получение сообщений от пользователей ===
def message_handler(update: Update, context: CallbackContext):
    anon = context.user_data.get('anon', True)
    username = update.message.from_user.username if update.message.from_user.username else update.message.from_user.first_name
    display_user = "Аноним" if anon else f"@{username}"
    text = update.message.text

    msg_id = len(pending_messages) + 1
    pending_messages[msg_id] = {"text": text, "user": display_user}

    # Кнопки для модерации
    keyboard = [
        [InlineKeyboardButton("Опубликовать ✅", callback_data=f"approve_{msg_id}")],
        [InlineKeyboardButton("Отклонить ❌", callback_data=f"reject_{msg_id}")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    context.bot.send_message(
        chat_id=YOUR_ID,
        text=f"Новое сообщение #{msg_id}:\n<b>{display_user}:</b> {text}",
        parse_mode='HTML',
        reply_markup=reply_markup
    )

    update.message.reply_text("Сообщение отправлено на модерацию ✅")

# === Обработка кнопок модерации для тебя ===
def moderation_buttons(update: Update, context: CallbackContext):
    query = update.callback_query
    query.answer()
    data = query.data

    if data.startswith("approve_"):
        msg_id = int(data.split("_")[1])
        msg = pending_messages.pop(msg_id, None)
        if msg:
            # Публикуем в канал красиво
            context.bot.send_message(
                chat_id=CHANNEL_ID,
                text=f"💌 Новое сообщение:\n<b>{msg['user']}:</b> {msg['text']}",
                parse_mode='HTML'
            )
            approved_text = f"{msg['user']}: {msg['text']}"
            approved_messages.append(approved_text)
            query.edit_message_text(f"Сообщение #{msg_id} одобрено ✅")
        else:
            query.edit_message_text("Сообщение уже обработано ❌")

    elif data.startswith("reject_"):
        msg_id = int(data.split("_")[1])
        pending_messages.pop(msg_id, None)
        query.edit_message_text(f"Сообщение #{msg_id} отклонено ❌")

# === Запуск бота ===
def main():
    updater = Updater(TOKEN)
    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(CallbackQueryHandler(button, pattern='^(anon|nonanon)$'))
    dp.add_handler(CallbackQueryHandler(moderation_buttons, pattern='^(approve|reject)_'))
    dp.add_handler(MessageHandler(Filters.text & ~Filters.command, message_handler))

    updater.start_polling()
    updater.idle()

if __name__ == '__main__':
    main()
